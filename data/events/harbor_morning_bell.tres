[gd_resource type="Resource" script_class="ScheduledEventDefinition" load_steps=8 format=3]

[ext_resource type="Script" path="res://src/Meridian/Data/ScheduledEventDefinition.cs" id="1_event"]
[ext_resource type="Script" path="res://src/Meridian/Data/Conditions/PlayerInRegionConditionResource.cs" id="2_region"]
[ext_resource type="Script" path="res://src/Meridian/Data/Actions/ShowNotificationActionResource.cs" id="3_notice"]
[ext_resource type="Script" path="res://src/Meridian/Data/Actions/SetWorldFlagActionResource.cs" id="4_flag"]

[sub_resource type="Resource" id="Condition_region"]
script = ExtResource("2_region")
RegionId = "harbor_town"

[sub_resource type="Resource" id="Action_notice"]
